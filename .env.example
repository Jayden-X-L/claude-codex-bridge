# Optional: choose explicit CLI binaries.
# AGENT_BRIDGE_CODEX_BIN=/absolute/path/to/codex
# AGENT_BRIDGE_CLAUDE_BIN=/absolute/path/to/claude

# Optional: tune default models.
# AGENT_BRIDGE_CODEX_MODEL=gpt-5.5
# AGENT_BRIDGE_CODEX_EFFORT=medium
# AGENT_BRIDGE_CLAUDE_MODEL=opus
# AGENT_BRIDGE_CLAUDE_EFFORT=medium

# Optional: bound Claude CLI spend for smoke tests.
# AGENT_BRIDGE_CLAUDE_MAX_BUDGET_USD=0.50

